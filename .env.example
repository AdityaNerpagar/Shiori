# ── LLM provider ─────────────────────────────────────────────
# "auto" (default): uses Anthropic if ANTHROPIC_API_KEY is set, otherwise Ollama.
# Force one with "anthropic" or "ollama".
LLM_PROVIDER=auto

# Paste an Anthropic API key here whenever you get one — it takes over automatically.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# Local Ollama (default provider until an Anthropic key is added)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3.5:27b
# Context window for Ollama requests (default 4096 is too small for deep episodes)
OLLAMA_NUM_CTX=16384

# ── Reddit comments (optional) ───────────────────────────────
# MAL forum threads work with no setup. Reddit r/anime episode-discussion
# threads activate automatically once these are filled in.
# Create a "script" app at https://www.reddit.com/prefs/apps to get them.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=shiori-local/0.1
