# ── LLM provider ─────────────────────────────────────────────
# "auto" (default): picks by key presence — Gemini, then Anthropic, then Ollama.
# Force one with "gemini", "anthropic", or "ollama".
LLM_PROVIDER=auto

# Google Gemini — the hosted-site default (free tier, no credit card).
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Anthropic — takes over automatically when set (and no Gemini key).
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# Local Ollama (default provider when no API key is set)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3.5:27b
# Context window for Ollama requests (default 4096 is too small for deep episodes)
OLLAMA_NUM_CTX=16384

# ── TMDB — general TV metadata (optional but recommended) ────
# Without it, search covers anime only (AniList). With it, any episodic
# TV show works. Free key: https://www.themoviedb.org/settings/api
# Accepts either a v3 API key or a v4 read-access token.
TMDB_API_KEY=

# ── Reddit comments (optional) ───────────────────────────────
# MAL forum threads work with no setup. Reddit episode-discussion
# threads (r/anime + per-show TV subreddits) activate automatically
# once these are filled in.
# Create a "script" app at https://www.reddit.com/prefs/apps to get them.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=shiori-local/0.1

# ── Research / tracing (optional) ────────────────────────────
# Every query builds a structured trace in memory (plan §11). Set to 1
# to persist traces as JSONL in .traces/ — OFF by default.
TRACE_LOG=
